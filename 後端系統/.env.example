# ── 資料庫（Railway 會自動注入 DATABASE_URL，不需手動填）──────────────
# DATABASE_URL=postgresql://user:pass@host:port/dbname

# ── 本地開發（SQLite）────────────────────────────────────────────────
USE_SQLITE=True
DEBUG=True

# ── 報告基底網址（改為你的 Railway 公開網址）─────────────────────────
REPORT_BASE_URL=https://your-app.railway.app/reports

# ── 統一金流 PAYUNi ────────────────────────────────────────────────
PAYUNI_MERCHANT=your_merchant_id
PAYUNI_HASH_KEY=your_hash_key
PAYUNI_HASH_IV=your_hash_iv

# ── LINE Messaging API（選填）────────────────────────────────────────
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# ── GCP Cloud Storage（選填）────────────────────────────────────────
GCS_BUCKET_NAME=
GCS_PROJECT_ID=
