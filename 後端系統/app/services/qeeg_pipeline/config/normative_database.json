{
  "_version": "1.2",
  "_note": "ThinkGear 單導程 Fp1 常模資料庫。log_mean 為實測校準值，log_sd 為 inter-individual（人與人之間）標準差。",
  "_provenance": {
    "log_mean_source": "ThinkGear Fp1 閉眼靜息實測校準（sessions 88, 89）：先計算每人 180 秒平均 → 跨人平均",
    "log_sd_source": "基於跨人 SD（inter-individual variability），來源：實測 2 sessions + 文獻下限保底（Teplan 2002, Nunez 2006）。⚠️ n=2 時部分頻段 raw SD 接近 0（如 theta），以文獻下限 0.30 保底。",
    "wrong_approach_v1.0_v1.1": "舊版錯誤：使用 within-session temporal SD（每秒波動），導致 log_sd 過大（0.65-0.99），Z-score 全部擠在 0 附近，所有人得分趨近 50，無法分化個體差異。",
    "fix_v1.2": "改用 session-level log mean（先每人平均再取 log），跨人 SD（inter-individual）作為常模 SD，各頻段 SD 控制在 0.30-0.50。",
    "calibration_sessions": [88, 89],
    "internal_norms_note": "當 sample_count >= 30 時，internal_norms 自動覆蓋 literature_adapted。"
  },

